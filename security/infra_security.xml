<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_infra" model="ir.module.category">
            <field name="name">LTD Infra</field>
            <field name="sequence">30</field>
        </record>

        <record id="group_infra_user" model="res.groups">
            <field name="name">Usuario</field>
            <field name="category_id" ref="module_category_infra"/>
        </record>

        <record id="group_infra_manager" model="res.groups">
            <field name="name">Gerente de Proyecto</field>
            <field name="category_id" ref="module_category_infra"/>
            <field name="implied_ids" eval="[(4, ref('group_infra_user'))]"/>
        </record>

        <record id="group_infra_admin" model="res.groups">
            <field name="name">Administrador</field>
            <field name="category_id" ref="module_category_infra"/>
            <field name="implied_ids" eval="[(4, ref('group_infra_manager'))]"/>
        </record>

    </data>
</odoo>
